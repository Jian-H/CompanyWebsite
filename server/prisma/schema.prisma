generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteContent {
  id                 Int      @id
  companyName        String
  slogan             String
  homeTitle          String
  homeSubtitle       String
  primaryActionLabel String
  primaryActionHref  String
  createdBy          String   @default("system")
  updatedBy          String   @default("system")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  displayName  String?
  role         String   @default("editor")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteSetting {
  id          Int      @id
  siteName    String
  logoText    String
  seoTitle    String
  seoDesc     String
  contactText String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HomeHero {
  id              Int      @id
  title           String
  highlight       String
  subtitle        String
  primaryLabel    String
  primaryHref     String
  secondaryLabel  String
  secondaryHref   String
  backgroundImage String
  isEnabled       Boolean  @default(true)
  updatedBy       String   @default("system")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model HomeAdvantage {
  id          Int      @id @default(autoincrement())
  icon        String
  title       String
  description String
  sortOrder   Int      @default(0)
  isEnabled   Boolean  @default(true)
  updatedBy   String   @default("system")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  coverImage  String
  href        String
  sortOrder   Int      @default(0)
  isEnabled   Boolean  @default(true)
  updatedBy   String   @default("system")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Solution {
  id          Int      @id @default(autoincrement())
  industry    String
  description String
  coverImage  String
  href        String
  sortOrder   Int      @default(0)
  isEnabled   Boolean  @default(true)
  updatedBy   String   @default("system")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Article {
  id          Int       @id @default(autoincrement())
  title       String
  category    String
  summary     String
  coverImage  String
  body        String
  isPublished Boolean   @default(true)
  publishedAt DateTime?
  sortOrder   Int       @default(0)
  updatedBy   String    @default("system")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
